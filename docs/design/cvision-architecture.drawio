<mxfile host="app.diagrams.net">
  <diagram name="CVision – System Architecture">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="CVision – High-Level System Architecture"
          style="text;html=1;align=center;fontSize=20;fontStyle=1"
          vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="600" height="40" as="geometry"/>
        </mxCell>

        <!-- Frontend -->
        <mxCell id="frontend"
          value="Frontend (React Web App)\n• Recruiter Dashboard\n• Applicant Interface"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf"
          vertex="1" parent="1">
          <mxGeometry x="50" y="150" width="260" height="120" as="geometry"/>
        </mxCell>

        <!-- Backend -->
        <mxCell id="backend"
          value="Backend API\n• Authentication\n• Business Logic\n• Resume Processing"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366"
          vertex="1" parent="1">
          <mxGeometry x="380" y="150" width="260" height="140" as="geometry"/>
        </mxCell>

        <!-- AI Engine -->
        <mxCell id="ai"
          value="AI Resume Analysis Engine\n• Resume Parsing\n• Scoring\n• Summary Generation"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656"
          vertex="1" parent="1">
          <mxGeometry x="380" y="330" width="260" height="140" as="geometry"/>
        </mxCell>

        <!-- Database -->
        <mxCell id="db"
          value="Database\n• User Data\n• Resumes\n• Scores &amp; Results"
          style="shape=cylinder;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450"
          vertex="1" parent="1">
          <mxGeometry x="720" y="170" width="200" height="120" as="geometry"/>
        </mxCell>

        <!-- Containerization -->
        <mxCell id="docker"
          value="Containerization\nDocker"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6"
          vertex="1" parent="1">
          <mxGeometry x="380" y="520" width="260" height="90" as="geometry"/>
        </mxCell>

        <!-- Deployment -->
        <mxCell id="deploy"
          value="Deployment / Infrastructure\n• Cloud Hosting\n• CI/CD Pipeline"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6e6e6;strokeColor=#666666"
          vertex="1" parent="1">
          <mxGeometry x="720" y="520" width="260" height="100" as="geometry"/>
        </mxCell>

        <!-- Arrows -->
        <mxCell id="a1" style="endArrow=block;html=1;" edge="1" parent="1" source="frontend" target="backend">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="a2" style="endArrow=block;html=1;" edge="1" parent="1" source="backend" target="db">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="a3" style="endArrow=block;html=1;" edge="1" parent="1" source="backend" target="ai">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="a4" style="endArrow=block;html=1;" edge="1" parent="1" source="ai" target="backend">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="a5" style="endArrow=block;html=1;" edge="1" parent="1" source="backend" target="docker">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="a6" style="endArrow=block
